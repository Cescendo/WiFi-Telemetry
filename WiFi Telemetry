            foreach ($line in ($out -split "`r?`n")) {
                if ($line -match '(?im)\bBSSID(?:\s+\d+)?\s*:\s*([0-9A-F]{2}(?:[-:][0-9A-F]{2}){5})\b') {
                    $wifi.BSSID = $Matches[1].Trim()
                    break
                }
            }
        }

        $gateway = ""
        try {
            $wifiIf = $null
            if (-not [string]::IsNullOrWhiteSpace($wifi.Interface)) {
                $wifiIf = Get-NetAdapter -Name $wifi.Interface -ErrorAction SilentlyContinue | Where-Object { $_.Status -eq "Up" } | Select-Object -First 1
            }
            if (-not $wifiIf) {
                $wifiIf = Get-NetAdapter | Where-Object { $_.Status -eq "Up" -and $_.Name -match "Wi-?Fi|WLAN" } | Select-Object -First 1
            }
            if (-not $wifiIf) {
                $wifiIf = Get-NetIPConfiguration | Where-Object { $_.IPv4DefaultGateway -ne $null } | Select-Object -First 1 | Select-Object -ExpandProperty NetAdapter -ErrorAction SilentlyContinue
            }
            if ($wifiIf) {
                $gateway = Get-NetIPConfiguration -InterfaceIndex $wifiIf.ifIndex |
                    Select-Object -ExpandProperty IPv4DefaultGateway -ErrorAction SilentlyContinue |
                    Select-Object -ExpandProperty NextHop -ErrorAction SilentlyContinue
            }
        } catch {}

        $gwPing = ""
        if (-not [string]::IsNullOrWhiteSpace($gateway)) {
            $gwPing = Get-PingMsFromExe $gateway
        }

        $internetPing = Get-PingMsFromExe $InnerInternetTarget
        $internalPing1 = Get-PingMsFromExe $InnerInternalTarget1
        $internalPing2 = Get-PingMsFromExe $InnerInternalTarget2

        $signalDbm = ""
        if ($wifi.SignalPercent -ne "") {
            $signalDbm = [math]::Round(($wifi.SignalPercent / 2) - 100, 0)
        }

        [PSCustomObject]@{
            Computer       = $env:COMPUTERNAME
            Interface      = $wifi.Interface
            State          = $wifi.State
            SSID           = $wifi.SSID
            BSSID          = $wifi.BSSID
            Radio          = $wifi.Radio
            Channel        = $wifi.Channel
            SignalPercent  = $wifi.SignalPercent
            SignalDbm      = $signalDbm
            Gateway        = $gateway
            GatewayPingMs  = $gwPing
            InternetPingMs = $internetPing
            InternalHost1PingMs = $internalPing1
            InternalHost2PingMs = $internalPing2
        }
    }

    $invokeParams = @{
        ComputerName = $TargetComputer
        ScriptBlock  = $scriptBlock
        ArgumentList = @($InternetTarget, $InternalTarget1, $InternalTarget2)
        ErrorAction  = "Stop"
    }
    if ($RemoteCredential) {
        $invokeParams.Credential = $RemoteCredential
    }

    return Invoke-Command @invokeParams
}

New-Item -ItemType Directory -Path $LocalOutputDir -Force | Out-Null

$safeComputerName = Get-SafeComputerName -InputComputerName $ComputerName
$lockFilePath = Join-Path $LocalOutputDir "wifi-telemetry_${safeComputerName}.lock"
Stop-PreviousInstanceIfNeeded -LockFilePath $lockFilePath
Set-Content -Path $lockFilePath -Value $PID -NoNewline -Encoding ascii
$currentPaths = Get-CsvPathsForHour -BaseOutputDir $OutputDir -BaseLocalOutputDir $LocalOutputDir -SafeComputerName $safeComputerName -Now (Get-Date)

try {
    New-Item -ItemType Directory -Path $OutputDir -Force | Out-Null
} catch {
    # Network path can be unavailable; local logging still proceeds.
}
Ensure-LocationServicesEnabled
[void](Try-EnsureNetworkCsvFile -FilePath $currentPaths.NetworkPath)
Ensure-CsvFile -FilePath $currentPaths.LocalPath
$lastSyncAt = (Get-Date).AddMinutes(-$SyncIntervalMinutes)
$lastKnownLoggedOnUser = ""

Write-Host "Network CSV: $($currentPaths.NetworkPath)"
Write-Host "Local CSV: $($currentPaths.LocalPath)"
Write-Host "Press Ctrl+C to stop."

try {
    while ($true) {
        $now = Get-Date
        $nowString = $now.ToString("yyyy-MM-dd HH:mm:ss")
        $detectedLoggedOnUser = Get-LoggedOnUser
        $isLocalTarget = $ComputerName -eq "." -or $ComputerName -eq "localhost" -or $ComputerName -ieq $env:COMPUTERNAME

        $expectedHourStamp = $now.ToString("yyyyMMdd_HH")
        if ($currentPaths.HourStamp -ne $expectedHourStamp) {
            $currentPaths = Get-CsvPathsForHour -BaseOutputDir $OutputDir -BaseLocalOutputDir $LocalOutputDir -SafeComputerName $safeComputerName -Now $now
            [void](Try-EnsureNetworkCsvFile -FilePath $currentPaths.NetworkPath)
            Ensure-CsvFile -FilePath $currentPaths.LocalPath
            Write-Host "Rotated to new hourly CSV: $($currentPaths.NetworkPath)"
        }

        $hasDetectedUser = (-not [string]::IsNullOrWhiteSpace($detectedLoggedOnUser)) -and
            (-not $detectedLoggedOnUser.Trim().Equals("Unknown", [System.StringComparison]::OrdinalIgnoreCase)) -and
            (-not $detectedLoggedOnUser.Trim().Equals("NoUserLoggedOn", [System.StringComparison]::OrdinalIgnoreCase))
        if ($hasDetectedUser) {
            $lastKnownLoggedOnUser = $detectedLoggedOnUser
        }
        $loggedOnUser = if ($hasDetectedUser) { $detectedLoggedOnUser } elseif (-not [string]::IsNullOrWhiteSpace($lastKnownLoggedOnUser)) { $lastKnownLoggedOnUser } else { "NoUserLoggedOn" }

        try {
            if ($isLocalTarget) {
                $sample = Get-LocalSnapshot -InternetTarget $InternetHost -InternalTarget1 $InternalHost1 -InternalTarget2 $InternalHost2
            } else {
                $sample = Get-RemoteSnapshot -TargetComputer $ComputerName -RemoteCredential $Credential -InternetTarget $InternetHost -InternalTarget1 $InternalHost1 -InternalTarget2 $InternalHost2
            }
        } catch {
            $sample = [PSCustomObject]@{
                Computer       = $ComputerName
                Interface      = ""
                State          = ""
                SSID           = ""
                BSSID          = ""
                Radio          = ""
                Channel        = ""
                SignalPercent  = ""
                SignalDbm      = ""
                Gateway        = ""
                GatewayPingMs  = ""
                InternetPingMs = ""
                InternalHost1PingMs = ""
                InternalHost2PingMs = ""
            }
        }

        $row = @(
            $nowString
            $sample.Computer
            $loggedOnUser
            $sample.Interface
            $sample.State
            $sample.SSID
            $sample.BSSID
            $sample.Radio
            $sample.Channel
            $sample.SignalPercent
            $sample.SignalDbm
            $sample.Gateway
            $sample.GatewayPingMs
            $InternetHost
            $sample.InternetPingMs
            $InternalHost1
            $sample.InternalHost1PingMs
            $InternalHost2
            $sample.InternalHost2PingMs
        ) -join ","

        Add-Content -Path $currentPaths.LocalPath -Value $row
        if (-not (Test-Path $currentPaths.NetworkPath)) {
            [void](Try-EnsureNetworkCsvFile -FilePath $currentPaths.NetworkPath)
        }
        [void](Try-AppendNetworkRow -FilePath $currentPaths.NetworkPath -Row $row)

        if (((Get-Date) - $lastSyncAt).TotalMinutes -ge $SyncIntervalMinutes) {
            if (Test-WlanAccessBlocked) {
                Ensure-LocationServicesEnabled
            }
            $currentHourStamp = $now.ToString("yyyyMMdd_HH")
            $syncStartHourStamp = $now.AddHours(-1 * [math]::Max(1, $SyncBacklogHours)).ToString("yyyyMMdd_HH")
            Sync-LocalCsvToNetwork -BaseLocalDir $LocalOutputDir -BaseNetworkDir $OutputDir -CurrentHourStamp $currentHourStamp -SyncStartHourStamp $syncStartHourStamp
            $lastSyncAt = Get-Date
        }
        Start-Sleep -Seconds $IntervalSeconds
    }
}
finally {
    try {
        $currentLockPid = Read-LockPid -LockFilePath $lockFilePath
        if ($currentLockPid -eq $PID -and (Test-Path $lockFilePath)) {
            Remove-Item -Path $lockFilePath -Force -ErrorAction SilentlyContinue
        }
    } catch {}
}
